{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account details and premium status",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "isPremium", "role"]
    },
    "Payment": {
      "title": "Payment Transaction",
      "description": "UPI payment submission for premium unlock",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "transactionId": { "type": "string", "description": "UTR number" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "transactionId", "amount", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles"
    },
    "payments/{paymentId}": {
      "schema": "Payment",
      "description": "Stores payment proof and status"
    }
  }
}
